// ============================================================
// RULE 1: ALL KNOWN C2 INFRASTRUCTURE
// ============================================================
let TeamPCP_C2_IPs = dynamic([
    "142.11.206.73",     // axios primary C2 (sfrclak.com)
    "23.254.167.216",    // axios secondary C2 (Breakglass confirmed)
    "23.254.203.244",    // axios secondary C2 (Breakglass confirmed)
    "45.148.10.212",     // TeamPCP/Trivy C2
    "83.142.209.11",     // TeamPCP/KICS C2 (checkmarx.zone)
    "83.142.209.203",    // Telnyx WAV steganography C2
    "172.86.105.40",     // BeaverTail C2
    "23.227.202.244",    // BeaverTail/InvisibleFerret C2
    "95.216.37.186",     // InvisibleFerret C2 (Breakglass confirmed)
    "95.164.17.24",      // InvisibleFerret C2
    "208.85.20.124"      // InvisibleFerret exfil server (Breakglass confirmed)
]);
let TeamPCP_C2_Domains = dynamic([
    "sfrclak.com",
    "checkmarx.zone",
    "scan.aquasecurtiy.org",
    "models.litellm.cloud",
    "tetrismic.vercel.app",
    "shabakinc.com",
    "nsa.cat",
    "packages.npm.org",
    "nvidiadriverupdate.cloud",
    "nvidiadriverupdate2.cloud",
    "nvidiagraphicsupdate.cloud",
    "nvidiagfxdriver.cloud",
    "nvidiagpudriver.cloud",
    "nvidiasdk.fly.dev",
    "tdtqy-oyaaa-aaaae-af2dq-cai.raw.icp0.io"
]);
DeviceNetworkEvents
| where Timestamp > ago(30d)
| where RemoteIP has_any(TeamPCP_C2_IPs) or RemoteUrl has_any(TeamPCP_C2_Domains)
| project Timestamp, DeviceName, RemoteIP, RemotePort, RemoteUrl, InitiatingProcessFileName, InitiatingProcessCommandLine, AccountUpn

// ============================================================
// RULE 2: C2 CALLBACK PORTS (high-confidence on non-standard)
// ============================================================
DeviceNetworkEvents
| where Timestamp > ago(7d)
| where RemotePort in (1224, 1244, 5918, 5934, 5961, 5974)
| where RemoteIPType == "Public"
| where InitiatingProcessFileName in ("node.exe", "node", "python.exe", "python3", "pythonw.exe")
| project Timestamp, DeviceName, RemoteIP, RemotePort, InitiatingProcessFileName, ProcessCommandLine

