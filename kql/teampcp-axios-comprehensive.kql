// ============================================================
// RULE 5: MALICIOUS NPM PACKAGE INSTALLATION
// ============================================================
DeviceProcessEvents
| where Timestamp > ago(30d)
| where InitiatingProcessFileName in ("npm.cmd", "npm", "npx.cmd", "npx", "yarn.cmd", "yarn", "pnpm.cmd", "pnpm")
| where ProcessCommandLine has_any(
    "plain-crypto-js",
    "separadordeinfocc",
    "undicy-http",
    "@emilgroup/",
    "@teale.io/",
    "consolelofy"
)
| project Timestamp, DeviceName, ProcessCommandLine, AccountUpn

// ============================================================
// RULE 6: PLAIN-CRYPTO-JS IN DEPENDENCY TREE
// ============================================================
DeviceFileEvents
| where Timestamp > ago(30d)
| where FolderPath has "node_modules" and FolderPath has "plain-crypto-js"
| project Timestamp, DeviceName, FolderPath, FileName, ActionType

// ============================================================
// RULE 7: AXIOS RAT PAYLOAD DROP PATHS
// ============================================================
let AxiosDropPaths = dynamic([
    @"\Library\Caches\com.apple.act.mond",
    @"\ProgramData\wt.exe",
    @"\Temp\ld.py"
]);
DeviceFileEvents
| where Timestamp > ago(30d)
| where FolderPath has_any(AxiosDropPaths)
    or (FileName == "com.apple.act.mond")
    or (FileName == "wt.exe" and FolderPath has "ProgramData")
    or (FileName == "ld.py" and FolderPath has "Temp")
| project Timestamp, DeviceName, FolderPath, FileName, SHA256, ActionType

// ============================================================
// RULE 8: TEAMPCP PERSISTENCE INDICATORS
// ============================================================
// Linux/macOS sysmon persistence
DeviceFileEvents
| where Timestamp > ago(30d)
| where FolderPath has_any(
    ".config/sysmon/sysmon.py",
    ".config/sysmon.py",
    ".config/systemd/user/sysmon.service",
    ".config/systemd/user/pgmon.service",
    "/var/lib/pgmon/pgmon.py"
)
| project Timestamp, DeviceName, FolderPath, FileName, ActionType

// ============================================================
// RULE 9: NVIDIA MASQUERADE PERSISTENCE (shared across campaigns)
// ============================================================
DeviceRegistryEvents
| where Timestamp > ago(30d)
| where ActionType == "RegistryValueSet"
| where RegistryKey has @"CurrentVersion\Run"
| where RegistryValueName has "Nvidia"
    and RegistryValueName has_any("Update", "Driver", "Notification", "Service", "Graphics", "Gpu", "Gfx", "SDK")
| where RegistryValueData !has @"C:\Program Files\NVIDIA Corporation"
    and RegistryValueData !has @"C:\Program Files (x86)\NVIDIA Corporation"
| project Timestamp, DeviceName, RegistryKey, RegistryValueName, RegistryValueData

// ============================================================
// RULE 10: KUBERNETES PERSISTENCE (TeamPCP DaemonSets)
// ============================================================
DeviceProcessEvents
| where Timestamp > ago(30d)
| where ProcessCommandLine has_any(
    "host-provisioner-iran",
    "host-provisioner-std",
    "pgmon",
    "internal-monitor",
    "pgmonitor"
)
| where ProcessCommandLine has_any("kubectl", "kube", "daemonset")
| project Timestamp, DeviceName, ProcessCommandLine

// ============================================================
// RULE 11: LEGACY USER-AGENT (axios RAT fingerprint)
// ============================================================
DeviceNetworkEvents
| where Timestamp > ago(7d)
| where AdditionalFields has "mozilla/4.0 (compatible; msie 8.0; windows nt 5.1; trident/4.0)"
| project Timestamp, DeviceName, RemoteIP, RemoteUrl, InitiatingProcessFileName

// ============================================================
// RULE 12: TPCP.TAR.GZ EXFILTRATION
// ============================================================
DeviceFileEvents
| where Timestamp > ago(30d)
| where FileName == "tpcp.tar.gz"
    or (FileName endswith ".tar.gz" and FolderPath has_any("/tmp/", @"\Temp\"))
| where InitiatingProcessFileName in ("node.exe", "node", "python.exe", "python3")
| project Timestamp, DeviceName, FolderPath, FileName, InitiatingProcessFileName

// ============================================================
// RULE 13: CREDENTIAL THEFT - CLOUD PROVIDER + SSH
// ============================================================
DeviceFileEvents
| where Timestamp > ago(7d)
| where ActionType == "FileRead"
| where (
    (FolderPath has @"\.ssh\" and FileName in ("id_rsa", "id_ed25519", "id_ecdsa", "known_hosts", "config", "authorized_keys"))
    or (FolderPath has @"\.aws\" and FileName == "credentials")
    or (FolderPath has @"\.azure\")
    or (FolderPath has @"\.config\gcloud\")
    or (FolderPath has @"\.kube\" and FileName == "config")
    or (FolderPath has @"\.docker\" and FileName == "config.json")
    or FileName == ".env"
    or FileName == ".npmrc"
    or FileName == ".pypirc"
)
| where InitiatingProcessFileName in ("node.exe", "node", "python.exe", "python3", "pythonw.exe", "cmd.exe", "powershell.exe", "pwsh.exe")
| where InitiatingProcessFileName !in ("code.exe", "explorer.exe", "sshd.exe", "ssh.exe", "git.exe", "aws.exe", "az.exe", "gcloud.exe", "kubectl.exe", "docker.exe")
| project Timestamp, DeviceName, FolderPath, FileName, InitiatingProcessFileName, InitiatingProcessCommandLine

// ============================================================
// RULE 14: COMPROMISED GITHUB ACTIONS REPOS
// ============================================================
DeviceProcessEvents
| where Timestamp > ago(30d)
| where ProcessCommandLine has_any(
    "aquasecurity/trivy-action",
    "checkmarx/kics-github-action",
    "checkmarx/ast-github-action",
    "RominaMabelRamirez/dify"
)
| project Timestamp, DeviceName, ProcessCommandLine, AccountUpn

// ============================================================
// RULE 15: WAV STEGANOGRAPHY DOWNLOAD (Telnyx attack vector)
// ============================================================
DeviceNetworkEvents
| where Timestamp > ago(7d)
| where RemoteIP == "83.142.209.203" and RemotePort == 8000
| union (
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FileName endswith ".wav"
    | where InitiatingProcessFileName in ("python.exe", "python3", "node.exe")
    | where FileSize > 1000000  // WAV steganography payloads are typically >1MB
)
| project Timestamp, DeviceName, FileName, RemoteIP, InitiatingProcessFileName

// ============================================================
// RULE 16: CONTAGIOUS INTERVIEW ENTRY VECTORS
// ============================================================
// Fake coding challenge repos cloned during interviews
DeviceProcessEvents
| where Timestamp > ago(7d)
| where InitiatingProcessFileName in ("git.exe", "git")
| where ProcessCommandLine has "clone"
| where ProcessCommandLine has_any(
    "tetrismic",
    "shabakinc",
    "RominaMabelRamirez",
    "coding-challenge",
    "interview-test",
    "assessment-project"
)
| project Timestamp, DeviceName, ProcessCommandLine, AccountUpn
