      "modified": "2026-04-29T10:52:00.000Z",
      "name": "KB C2 Panel",
      "description": "Web-based C2 management dashboard (React SPA v2.0) for the KB C2 framework. Provides bot management, command execution, credential viewing, DDoS attack builder, cryptominer control, agent/dropper builder, lure management, and mass email capabilities.",
      "tool_types": ["remote-access"],
      "tool_version": "2.0"
    },
