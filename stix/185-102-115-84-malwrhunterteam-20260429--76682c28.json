      "name": "KB C2 Operator",
      "description": "Russian-speaking threat actor operating the KB C2 botnet framework, targeting Ukrainian organizations with phishing lures impersonating PrivatBank, Ukrposhta, DPS (tax authority), and Diia (government services). Operator UI is in Russian; victim-facing content is in Ukrainian.",
      "threat_actor_types": ["criminal"],
      "roles": ["operator", "infrastructure-operator"],
      "sophistication": "advanced",
      "primary_motivation": "personal-gain",
      "secondary_motivations": ["ideology"]
    },
    {
      "type": "malware",
      "id": "malware--f5a3d2b1-6e4c-4f9a-b8d7-1c2e3f4a5b60",
      "spec_version": "2.1",
      "created": "2026-04-29T10:52:00.000Z",
      "modified": "2026-04-29T10:52:00.000Z",
      "name": "KB C2",
      "description": "Full-featured C2 framework with Rust backend (axum/tokio), React SPA frontend, and Rust agent. Capabilities include: remote shell, credential theft, DDoS, cryptomining (Monero), SOCKS5 proxy, lateral movement, DLL sideloading, HTML smuggling, and mass phishing. Uses JWT auth, WebSocket for bot communication, MongoDB for persistence, and AES-256-GCM+ECDH encryption.",
      "malware_types": ["remote-access-trojan", "botnet"],
      "is_family": true,
      "aliases": ["kb-agent", "kb-botnet-2026"],
      "first_seen": "2026-04-29T00:00:00.000Z",
      "capabilities": [
        "accesses-remote-machines",
        "captures-input-peripherals",
        "communicates-with-c2",
        "compromises-data-availability",
        "compromises-data-integrity",
        "compromises-system-availability",
        "escalates-privileges",
        "exfiltrates-data",
        "persists-after-system-reboot",
        "steals-authentication-credentials"
      ],
      "architecture_execution_envs": ["windows-x86-64"],
      "implementation_languages": ["Rust"]
    },
    {
