      "created": "2026-04-28T11:00:00.000Z",
      "modified": "2026-04-28T11:00:00.000Z",
      "name": "Chopi RAT",
      "description": "Custom C2 implant delivered as .ocx DLL. Features: remote shell, file manager, screen capture, keylogging, audio capture, clipboard monitoring, Chrome/Edge data theft, NTLM capture, token impersonation, SOCKS proxy. Executed via regsvr32 /s /i.",
      "malware_types": ["remote-access-trojan", "spyware", "credential-stealer"],
      "is_family": true,
      "created_by_ref": "identity--ghost-intel-breakglass"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--chromelevator-2026",
      "created": "2026-04-28T11:00:00.000Z",
      "modified": "2026-04-28T11:00:00.000Z",
      "name": "chromelevator",
      "description": "Chrome/Edge credential and cookie stealer module. Uses direct syscalls to bypass EDR hooks. Extracts cookies, passwords, payment cards, IBANs, tokens, and browser profiles. Logs to C:\\ProgramData\\xlog.txt.",
      "malware_types": ["credential-stealer"],
      "is_family": false,
      "created_by_ref": "identity--ghost-intel-breakglass"
    },
