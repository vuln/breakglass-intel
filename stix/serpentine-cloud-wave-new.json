    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--09c0d1e2-f3a4-4b5c-6d7e-8f9a0b1c2d3e",
      "created": "2026-03-31T22:15:00.000Z",
      "modified": "2026-03-31T22:15:00.000Z",
      "content": "The Donut shellcode modules are encrypted with Chaskey cipher within the Donut instance. The final .NET RAT payload could not be extracted without dynamic execution. Based on previous SERPENTINE#CLOUD waves, the final payload is likely AsyncRAT, XWorm, VenomRAT, or DcRAT. The two own.enc files decrypt to different shellcode, suggesting different C2 configurations for redundancy.",
      "object_refs": [
        "campaign--d1e2f3a4-b5c6-4d7e-8f9a-0b1c2d3e4f5a"
      ]
    }
