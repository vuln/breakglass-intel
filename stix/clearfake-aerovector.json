    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--analysis-summary-001",
      "created": "2026-04-01T04:41:30.000Z",
      "modified": "2026-04-01T04:41:30.000Z",
      "content": "Investigation by GHOST (Breakglass Intelligence) on 2026-04-01. Starting from a single ThreatFox IOC (pilot-svc.aerovector.in.net), mapped 24 parent domains across 2 Cloudflare accounts, recovered 3 previously unknown payloads (2 Go/garble DLLs + 1 HTML lure), and documented a WebDAV-based delivery mechanism with PROPFIND directory listing exposure. Neither DLL was previously known to VirusTotal or MalwareBazaar.",
      "object_refs": [
        "campaign--clearfake-aerovector-2026",
        "malware--clearfake-idpagent-001",
        "malware--clearfake-strprov-001",
        "infrastructure--clearfake-webdav-001"
      ],
      "created_by_ref": "identity--breakglass-ghost-001"
    }
  ]
