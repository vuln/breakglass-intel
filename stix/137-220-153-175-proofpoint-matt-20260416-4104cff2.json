    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--config-analysis",
      "created": "2026-04-16T18:00:00.000Z",
      "modified": "2026-04-16T18:00:00.000Z",
      "content": "Malware config contains Campaign_ID '默认备注' (default remark) and Operator_ID '默认分组' (default group) — stock Chinese-language defaults in Gh0st RAT / ValleyRAT panel builders. Operator did not customize campaign identifiers, suggesting either new operator or deliberate opsec practice.",
      "object_refs": ["malware--valleyrat-winos40-001"]
