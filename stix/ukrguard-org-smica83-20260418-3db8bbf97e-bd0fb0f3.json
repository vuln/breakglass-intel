    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--investigation-context",
      "created": "2026-04-18T19:00:00.000Z",
      "modified": "2026-04-18T19:00:00.000Z",
      "content": "Investigation initiated from @smica83 tweet on 2026-04-18. Domain ukrguard.org found hosting fake 'Commercial Proposal for Ground Control from Ukrguard Charitable Foundation' delivering proposal.hta via mshta.exe. Campaign matches CERT-UA UAC-0247 cluster (advisory 6288271, published ~2026-04-15). Hosting on AS216127 (nuxt.cloud) in Frankfurt, Germany. No file hashes available in public reporting at time of investigation.",
      "object_refs": ["campaign--uac0247-agingfly-2026q1"]
    }
