      "modified": "2026-04-18T19:00:00.000Z",
      "name": "UAC-0247",
      "description": "Threat cluster tracked by CERT-UA targeting Ukrainian government entities, municipal healthcare institutions, and FPV drone operators using charity-themed phishing lures and custom malware including AGINGFLY RAT, RAVENSHELL, and SILENTLOOP.",
      "threat_actor_types": ["nation-state"],
      "aliases": ["UAC-0247"],
      "roles": ["agent"],
      "goals": ["Espionage", "Credential Theft", "Data Exfiltration", "Persistent Access"],
      "sophistication": "advanced",
      "resource_level": "government",
      "primary_motivation": "organizational-gain"
    },
    {
      "type": "campaign",
      "spec_version": "2.1",
      "id": "campaign--uac0247-agingfly-2026q1",
      "created": "2026-04-18T19:00:00.000Z",
      "modified": "2026-04-18T19:00:00.000Z",
      "name": "UAC-0247 Charity-Themed Phishing Campaign (2026)",
      "description": "Campaign using fake charitable foundation websites and humanitarian aid proposals to deliver AGINGFLY RAT and associated tools to Ukrainian targets.",
      "first_seen": "2026-03-01T00:00:00.000Z",
      "last_seen": "2026-04-18T19:00:00.000Z"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--agingfly-rat-2026",
      "created": "2026-04-18T19:00:00.000Z",
      "modified": "2026-04-18T19:00:00.000Z",
      "name": "AGINGFLY",
      "description": "C#-based Remote Access Trojan using WebSocket C2 communication with AES-CBC encryption. Capable of keylogging, file download, payload execution, and screen capture. Uniquely compiles command handlers on-host from source code received from C2 server.",
      "malware_types": ["remote-access-trojan"],
      "is_family": true,
      "capabilities": ["accesses-remote-machines", "captures-input-peripherals", "captures-output-peripherals", "exfiltrates-data"]
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--ravenshell-2026",
      "created": "2026-04-18T19:00:00.000Z",
      "modified": "2026-04-18T19:00:00.000Z",
      "name": "RAVENSHELL",
      "description": "TCP reverse shell establishing C2 connections via cmd.exe execution with 9-byte XOR encryption.",
      "malware_types": ["backdoor"],
      "is_family": true
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--silentloop-2026",
      "created": "2026-04-18T19:00:00.000Z",
      "modified": "2026-04-18T19:00:00.000Z",
      "name": "SILENTLOOP",
      "description": "PowerShell persistence script with command execution, auto-update, and Telegram-based C2 address retrieval with fallback mechanisms.",
      "malware_types": ["backdoor"],
      "is_family": true
    },
