      "sophistication": "expert",
      "resource_level": "government",
      "primary_motivation": "organizational-gain"
    },
    {
      "type": "campaign",
      "spec_version": "2.1",
      "id": "campaign--faktyra-invstampvest-2026-04",
      "created": "2026-04-17T00:00:00.000Z",
      "modified": "2026-04-17T00:00:00.000Z",
      "name": "Kimsuky Invoice Lure Campaign (faktyra/invstampvest)",
      "description": "Campaign using Bulgarian-language invoice-themed ZIP lures (faktyra-850344.zip) delivered via invstampvest.com, with C2 infrastructure at check.nid-log.com. Multi-stage attack chain: CHM dropper -> VBScript stager -> PowerShell keylogger.",
      "first_seen": "2026-02-26T00:00:00.000Z",
      "last_seen": "2026-04-17T00:00:00.000Z"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--kimsuky-chm-keylogger-2026",
      "created": "2026-04-17T00:00:00.000Z",
      "modified": "2026-04-17T00:00:00.000Z",
      "name": "Kimsuky CHM Keylogger",
      "description": "Multi-stage malware chain: CHM dropper delivers VBScript recon stager, which establishes persistence via scheduled task and downloads PowerShell keylogger with clipboard monitoring. Uses typo'd User-Agents (Chremo, Edgo) and multipart POST exfiltration.",
      "malware_types": ["keylogger", "spyware", "dropper"],
      "is_family": true,
      "capabilities": ["anti-detection", "persists-after-system-reboot", "captures-input-peripherals", "exfiltrates-data"]
    },
