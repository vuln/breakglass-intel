    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--b06066fa-5001-4a00-b001-000000000001",
      "created": "2026-04-15T17:00:00.000Z",
      "modified": "2026-04-15T17:00:00.000Z",
      "content": "Evasion techniques observed: (1) IP blocklist of Cloudflare scanner IPs 162.158.63.160-162 with redirect to easternbank.com, (2) Mobile device filtering - only desktop users reach payload, (3) Compromised legitimate site used as redirect host, (4) 5-second JavaScript delay before payload page. The complete.php endpoint timed out during analysis - may require specific referrer or session cookies.",
      "object_refs": [
        "campaign--b06066fa-0002-4a00-b001-000000000001"
      ],
      "created_by_ref": "identity--b06066fa-0001-4a00-b001-000000000001"
    },
