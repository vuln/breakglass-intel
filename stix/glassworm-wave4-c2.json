      "id": "malware--glassworm",
      "created": "2026-04-01T04:44:00.000Z",
      "modified": "2026-04-01T04:44:00.000Z",
      "name": "GlassWorm",
      "description": "JavaScript-based supply chain infostealer and RAT. Delivered via compromised VS Code extensions and npm packages. Uses AES-256-CBC encryption, Unicode steganography, Solana blockchain for C2 resolution, and BitTorrent DHT as backup. Targets cryptocurrency wallets, browser credentials, SSH keys, cloud tokens, and developer credentials.",
      "malware_types": [
        "remote-access-trojan",
        "spyware",
        "backdoor"
      ],
      "is_family": true,
      "aliases": [
        "js.glassworm"
      ],
      "first_seen": "2025-10-01T00:00:00.000Z",
      "last_seen": "2026-04-01T04:44:00.000Z",
      "capabilities": [
        "accesses-remote-machines",
        "captures-input-peripherals",
        "communicates-with-c2",
        "exfiltrates-data",
        "persists-after-system-reboot",
        "steals-authentication-credentials"
      ],
      "operating_system_refs": [
        "macos",
        "windows"
      ]
    },
