    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--port5000-analysis",
      "created": "2026-04-01T04:44:00.000Z",
      "modified": "2026-04-01T04:44:00.000Z",
      "content": "Port 5000 on 217.69.2.135 hosts an Express.js API with Helmet security headers and CORS configured for localhost:3000. This is assessed with MEDIUM confidence to be an operator management panel API -- a new capability not documented in prior GlassWorm reporting. The CORS configuration indicates the operator runs a React/Next.js frontend locally that connects to this remote API backend for campaign management.",
      "object_refs": [
        "infrastructure--c2-217-69-2-135"
      ]
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--new-ips-discovered",
      "created": "2026-04-01T04:44:00.000Z",
      "modified": "2026-04-01T04:44:00.000Z",
      "content": "Two previously unreported C2 IPs discovered through Solana blockchain analysis: 217.69.0.159 (active Mar 13-15, 2026) and 45.76.44.240 (brief use Mar 13, 2026). These were not included in the Codeberg writeup or ThreatFox submissions at time of analysis. The Solana blockchain provides a complete, immutable audit trail of all C2 rotations.",
