    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--dual-tool-analysis",
      "created": "2026-04-01T00:59:12.000Z",
      "modified": "2026-04-01T00:59:12.000Z",
      "content": "The operator uses a dual-tool setup: MeshCentral (legitimate RMM) for plausible deniability and Quasar RAT for full C2 capabilities. MeshCentral traffic blends with legitimate IT management traffic, making detection harder. The Quasar RAT certificate was generated Sep 1, 2025 and the MeshCentral instance has been active since Dec 21, 2025. The Windows server hostname WIN-JR2I61EMQ2H and IP registration to a Private Customer in Grove City, OH are the primary attribution leads.",
      "object_refs": [
        "threat-actor--znzglobalsol-operator",
        "infrastructure--quasar-c2-server"
      ]
    }
