      "modified": "2026-04-16T00:00:00.000Z",
      "name": "Custom PowerShell Reverse Shell (savi.ps1 / Another.ps1 / muskil.ps1)",
      "description": "Obfuscated PowerShell reverse TCP shell with hex-encoded C2 IP, randomized variable names (256+ chars), mixed-case .NET types, and comment padding. Connects to C2 on port 4443, executes arbitrary commands via Invoke-Expression, auto-reconnects every 5 seconds.",
      "malware_types": ["backdoor", "remote-access-trojan"],
      "is_family": true,
      "capabilities": ["communicates-with-c2", "exfiltrates-data"],
      "implementation_languages": ["PowerShell"]
    },
