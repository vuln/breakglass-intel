    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--investigation-summary",
      "created": "2026-03-31T00:00:00Z",
      "modified": "2026-03-31T00:00:00Z",
      "content": "Investigation initiated from @nahamike01 tweet reporting a1iyun.top as C2. Full pivot revealed this is a large-scale Chinese VPN circumvention operation (ChainVPN/AndyVPN) using typosquat domains of Alibaba Cloud. The Windows client contains keylogging indicators (GetAsyncKeyState) and an encrypted SQLite database for VPN server configuration. The operation maintains 25+ domains across 4 registrars and 10+ IPs exclusively on Alibaba Cloud and Cogent Communications. The PHP 5.4.45 backend and exposed .env/.git files indicate poor operational security despite extensive domain redundancy.",
      "object_refs": ["threat-actor--andyvpn-operator", "campaign--andyvpn-distribution"],
      "created_by_ref": "identity--bgi-ghost-analyst"
    }
