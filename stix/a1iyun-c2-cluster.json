    {
      "type": "threat-actor",
      "spec_version": "2.1",
      "id": "threat-actor--andyvpn-operator",
      "created": "2026-03-31T00:00:00Z",
      "modified": "2026-03-31T00:00:00Z",
      "name": "AndyVPN/ChainVPN Operator",
      "description": "Chinese-nexus operator running a large-scale GFW circumvention VPN service distributed through typosquat domains mimicking Alibaba Cloud (a1iyun). Maintains 25+ domains, 10+ IPs across Alibaba Cloud and Cogent Communications. Uses affiliate/referral tracking, Baidu Analytics, and QQ Messenger for customer support.",
      "threat_actor_types": ["criminal"],
      "aliases": ["ChainVPN", "AndyVPN", "a1iyun operator"],
      "roles": ["infrastructure-operator", "malware-author"],
      "sophistication": "intermediate",
      "resource_level": "organization",
      "primary_motivation": "personal-gain",
      "goals": ["Financial gain through VPN subscription service", "Potential surveillance of VPN users"],
      "created_by_ref": "identity--bgi-ghost-analyst"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--andyvpn-windows-client",
      "created": "2026-03-31T00:00:00Z",
      "modified": "2026-03-31T00:00:00Z",
      "name": "AndyVPN Windows Client",
      "description": "NSIS-packaged VPN client using V2Ray/Shadowsocks protocols. Contains encrypted SQLite database (Data.dat) for VPN server configuration. Uses DuiLib Chinese UI framework, Windows CryptoAPI for encryption, TAP driver for network tunneling, and PAC files for split routing. GetAsyncKeyState import suggests potential keylogging capability.",
      "malware_types": ["remote-access-trojan"],
      "is_family": true,
      "capabilities": ["communicates-with-c2", "captures-input-peripherals", "persists-after-system-reboot", "installs-other-components"],
      "created_by_ref": "identity--bgi-ghost-analyst"
    },
    {
      "type": "malware",
