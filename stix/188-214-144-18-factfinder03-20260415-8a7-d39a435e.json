      "name": "Curse Panel Telegram Infrastructure",
      "description": "Telegram-based infrastructure used for OTP delivery, exfiltration alerts, data theft bot operation, and malware sales.",
      "infrastructure_types": ["command-and-control", "exfiltration"],
