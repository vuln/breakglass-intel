    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--a1234567-b890-4cde-f012-3456789abcde",
      "created": "2026-04-17T00:00:00.000Z",
      "modified": "2026-04-17T00:00:00.000Z",
      "name": "Curse Panel",
      "description": "Curse Panel is a Malware-as-a-Service Android banking RAT and infostealer C2 panel. Features include SMS interception/forwarding, call forwarding, keylogging, gallery extraction, UPI PIN theft, USSD execution, APK payload deployment, and Telegram-based exfiltration. Specifically targets Indian victims (UPI, Aadhaar). Uses Firebase RTDB as backend and Socket.IO for real-time C2.",
      "malware_types": ["remote-access-trojan", "spyware", "backdoor"],
      "is_family": true,
      "aliases": ["CursePanel", "Curse Stealer", "CurseTango"],
      "operating_system_refs": ["android"],
      "capabilities": [
        "accesses-remote-machines",
        "captures-input-peripherals",
        "captures-output-peripherals",
        "captures-system-state-data",
        "communicates-with-c2",
        "compromises-data-availability",
        "compromises-data-integrity",
        "compromises-system-availability",
        "exfiltrates-data",
        "steals-authentication-credentials"
      ],
      "created_by_ref": "identity--f1e2d3c4-b5a6-4978-8a6b-5c4d3e2f1a0b"
    },
    {
      "type": "infrastructure",
      "spec_version": "2.1",
      "id": "infrastructure--b2345678-c901-4def-0123-456789abcdef",
      "created": "2026-04-17T00:00:00.000Z",
      "modified": "2026-04-17T00:00:00.000Z",
      "name": "Curse Panel C2 Server",
      "description": "Primary C2 server hosting Curse Panel web interface on AlexHost SRL infrastructure in Moldova (AS200019). Runs Node.js/Express with Socket.IO and Firebase RTDB backend. Ports: 22, 80, 443, 3389, 5985, 5986.",
      "infrastructure_types": ["command-and-control"],
      "created_by_ref": "identity--f1e2d3c4-b5a6-4978-8a6b-5c4d3e2f1a0b"
    },
