    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--n1111111-aaaa-4bbb-cccc-dddddddddddd",
      "created": "2026-04-17T00:00:00.000Z",
      "modified": "2026-04-17T00:00:00.000Z",
      "content": "First-to-report: No prior public reporting found for Curse Panel malware family. Zero coverage on abuse.ch (ThreatFox, MalwareBazaar) at time of investigation. Panel confirmed live 2026-04-17 with HTML last modified same day. Fraud workflow tags (Cashout Done, Big/Small Connection, No Aadhaar, Pin Set) confirm active financial fraud operations targeting Indian UPI ecosystem.",
      "object_refs": ["malware--a1234567-b890-4cde-f012-3456789abcde"],
