    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--analysis-summary",
      "created": "2026-04-01T04:16:18.000Z",
      "modified": "2026-04-01T04:16:18.000Z",
      "content": "This PlugX DLL sideloading loader was uploaded from Russia on 2026-03-31, 15 days after its compilation timestamp. The MIDL type library embedded in the DLL dates to 2016, indicating 10+ years of tooling reuse consistent with Mustang Panda. The unique imphash suggests a distinct build chain from other recent PlugX samples. The companion encrypted payload (.dat file) was not recovered, preventing direct C2 configuration extraction. Three known PlugX C2 domains were identified sharing the same Cloudflare account and NameCheap registrar. March 2026 MalwareBazaar uploads show high operational tempo with diverse lure themes (Middle East energy, Vietnamese government, OECD policy).",
      "object_refs": [
        "malware--plugx-vqqspeeddl-loader",
        "threat-actor--mustang-panda"
      ]
    }
