    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--sheetrat-analysis",
      "created": "2026-03-31T17:19:45.000Z",
      "modified": "2026-03-31T17:19:45.000Z",
      "content": "SheetRAT v2.6.4 is a .NET RAT framework using Pinggy tunnels for C2 (not Google Sheets as the name implies). The builder applies monoalphabetic substitution cipher with per-build randomized alphabets to obfuscate operational strings. The framework includes 32 plugin modules. Five samples were identified in a 3-day window (March 29-31, 2026) all sharing imphash f34d5f2d4577ed6d9ceec516c1f5a744. Developer PDB path reveals username 'Malware' and Russian-language GitHub distribution suggests CIS-origin development. This is the first public threat intelligence report on SheetRAT.",
      "object_refs": [
        "malware--sheetrat-264"
      ]
    }
  ]
