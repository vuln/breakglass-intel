      "created": "2026-03-31T17:19:45.000Z",
      "modified": "2026-03-31T17:19:45.000Z",
      "name": "SheetRAT",
      "description": "SheetRAT v2.6.4 is a .NET-based Remote Access Trojan distributed as an open-source builder kit. Despite its name, it uses Pinggy TCP tunnels for C2 (not Google Sheets). Includes 32 plugin modules for credential theft, DDoS, crypto mining, worm propagation, and more.",
      "malware_types": [
        "remote-access-trojan",
        "backdoor"
      ],
      "is_family": true,
      "aliases": [
        "SheetRat",
        "Sheet rat"
      ],
      "first_seen": "2025-12-19T00:00:00.000Z",
      "last_seen": "2026-03-31T17:19:45.000Z",
      "architecture_execution_envs": [
        "x86"
      ],
      "implementation_languages": [
        "c#"
      ],
      "capabilities": [
        "communicates-with-c2",
        "captures-input-peripherals",
        "captures-output-peripherals",
        "persists-after-system-reboot",
        "escalates-privileges",
        "steals-authentication-credentials",
        "degrades-security-software",
        "probes-network-environment"
      ]
    },
