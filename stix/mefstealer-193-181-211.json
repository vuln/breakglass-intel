    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--56789012-def0-1234-5678-9abcdef01234",
      "created": "2026-04-03T03:00:00.000Z",
      "modified": "2026-04-03T03:00:00.000Z",
      "content": "The MefStealer C2 panel at 193.181.211.79:5001 has zero victims as of 2026-04-03. The infrastructure appears to be in a pre-operational staging phase. The panel was first observed tracking daily statistics from 2026-03-05. Critical OPSEC failures include: (1) hostname 'forustvps' leaked via unauthenticated Checkmk agent, (2) operator portfolio at chernuha.space co-hosted on same IP, (3) squad members listed on portfolio with links to personal domains, (4) residential Slovak IPs exposed via subdomains.",
      "object_refs": ["threat-actor--a1b2c3d4-e5f6-7890-abcd-ef1234567890", "infrastructure--c3d4e5f6-a7b8-9012-cdef-123456789012"]
    }
