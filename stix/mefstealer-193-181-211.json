      "modified": "2026-04-03T03:00:00.000Z",
      "name": "MefStealer",
      "description": "Information stealer with a Python-based C2 infrastructure. The gate (Flask/Werkzeug on port 5000) accepts multipart file uploads of stolen data. The panel (FastAPI/Uvicorn on port 5001) provides a web interface for browsing stolen credentials, cookies, Telegram session data, crypto wallets, VPN configs, and files.",
      "malware_types": ["spyware", "credential-stealer"],
      "is_family": true,
      "capabilities": ["steals-authentication-credentials", "accesses-user-data", "exfiltrates-data"]
    },
