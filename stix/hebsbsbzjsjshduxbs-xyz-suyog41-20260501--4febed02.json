      "name": "SHub Stealer Primary C2 Server",
      "description": "Flask-based C2 server behind Cloudflare serving malware payloads, receiving exfiltrated data, distributing backdoored wallet applications, and supporting remote command execution via heartbeat.",
      "infrastructure_types": ["command-and-control"]
    },
