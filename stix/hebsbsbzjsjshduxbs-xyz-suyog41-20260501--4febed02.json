      "modified": "2026-05-01T11:00:00.000Z",
      "name": "SHub Stealer",
      "description": "macOS AppleScript-based infostealer targeting cryptocurrency wallets, browser credentials, keychains, and system data. Features wallet application backdooring, remote command execution via heartbeat, and CIS geofencing.",
      "malware_types": ["spyware", "trojan"],
      "is_family": true,
      "aliases": ["SHub", "SHubStealer"],
      "operating_system_refs": ["software--macos"],
      "capabilities": ["accesses-remote-machines", "captures-input-peripherals", "communicates-with-c2", "compromises-data-integrity", "exfiltrates-data", "persists-after-system-reboot", "steals-authentication-credentials"]
    },
    {
