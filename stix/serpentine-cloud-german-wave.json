    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--analysis-summary",
      "created": "2026-04-01T18:28:33.000Z",
      "modified": "2026-04-01T18:28:33.000Z",
      "content": "SERPENTINE#CLOUD German Wave is the first German-targeted variant of this campaign cluster. Key differentiators: Python-based KISS Loader (instead of DLL sideloading), PurePythonObfuscator for key generation, IHK.de invoice decoy, dual-payload delivery (dcRAT + XenoRAT), and custom Donut shellcode variant with big-endian counter increment in Chaskey-CTR decryption. The revive.bat persistence script references a different install path (lg07) than job.bat (vours), indicating tooling reuse across campaign waves.",
      "object_refs": [
        "campaign--serpentine-cloud-german-wave"
      ]
    }
