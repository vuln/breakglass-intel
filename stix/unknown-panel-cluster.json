    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--riptide-proxy",
      "created": "2026-03-31T19:00:00.000Z",
      "modified": "2026-03-31T19:00:00.000Z",
      "name": "Riptide",
      "description": "Custom Go-based dual-protocol (HTTP/SOCKS5) proxy tunneling server. Features include upstream proxy chaining via SOCKS5, Redis-backed upstream selection, ClickHouse analytics, per-user bandwidth throttling, distributed rate limiting, and DNS caching. Binary deployed as /root/riptide/riptide on Linux servers. Compiled on Windows by user 'Kompiuteris' and distributed via Telegram Desktop.",
      "malware_types": ["remote-access-trojan"],
      "is_family": true,
      "created_by_ref": "identity--breakglass-intel-ghost"
    },
    {
      "type": "tool",
      "spec_version": "2.1",
      "id": "tool--subway-kount-generator",
