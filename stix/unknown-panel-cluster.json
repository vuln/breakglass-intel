      "modified": "2026-03-31T19:00:00.000Z",
      "name": "Subway Kount Session Generator",
      "description": "Credential stuffing tool that generates fake iOS device fingerprints (iPhone 13/14 Pro, iOS 16.0) and OAuth2 PKCE sessions for attacking Subway loyalty accounts via Azure AD B2C. Includes Adobe Analytics cookie injection for Kount antifraud bypass.",
      "tool_types": ["credential-exploitation"],
