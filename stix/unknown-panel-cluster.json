      "id": "note--investigation-summary",
      "created": "2026-03-31T19:00:00.000Z",
      "modified": "2026-03-31T19:00:00.000Z",
      "abstract": "Operation Riptide - GHOST Investigation Summary",
      "content": "Critical OPSEC failure: Go pprof debug endpoints exposed on port 666 across all 8 Riptide nodes revealed complete source code architecture, developer identity (Windows user 'Kompiuteris', Lithuanian), Telegram-based distribution, and full technology stack. Infrastructure processes 34,000-367,000 concurrent proxy connections. Co-located Subway credential stuffing tool discovered on same subnet. Zero prior threat intelligence coverage -- first documented by Breakglass Intelligence.",
      "object_refs": ["threat-actor--riptide-operator", "malware--riptide-proxy", "infrastructure--riptide-cluster"],
      "created_by_ref": "identity--breakglass-intel-ghost"
    }
