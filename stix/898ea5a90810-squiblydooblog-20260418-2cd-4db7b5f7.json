      "name": "Tauri Teams Launcher RAT",
      "description": "Custom Rust/Tauri-based RAT and infostealer masquerading as Microsoft Teams installer. Capabilities include keylogging, screenshot capture, OAuth token theft via app-launcher:// protocol handler, Python script execution, secondary payload download, and HTTPS C2 polling. Built with Tauri 2.10.2 framework. Signed with a fraudulent Chinese EV code-signing certificate.",
      "malware_types": ["remote-access-trojan", "spyware", "trojan"],
      "is_family": false,
      "kill_chain_phases": [
