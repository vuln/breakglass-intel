      "name": "NEXUS-PHISH Operator",
      "description": "Unattributed threat actor operating multi-campaign phishing infrastructure targeting financial institutions, tech platforms, and cryptocurrency users, alongside SheetRAT C2 operations. Active since at least November 2022.",
      "threat_actor_types": [
        "criminal"
      ],
      "sophistication": "intermediate",
      "resource_level": "individual",
      "primary_motivation": "financial-gain",
      "aliases": []
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--sheetrat-001",
      "created": "2026-04-03T14:20:00.000Z",
      "modified": "2026-04-03T14:20:00.000Z",
      "name": "SheetRAT",
      "description": ".NET-based Remote Access Trojan derived from VenomRAT/AsyncRAT lineage. Features character substitution string obfuscation, ETW/AMSI bypass, Windows Defender exclusion, WMI-based VM detection, camera access, and Schtasks/Registry persistence.",
      "malware_types": [
        "remote-access-trojan"
      ],
      "is_family": true,
      "capabilities": [
        "accesses-remote-machines",
        "captures-input-peripherals",
        "persists-after-system-reboot",
        "communicates-with-c2",
        "degrades-security-software"
      ],
      "implementation_languages": [
        "C#"
      ]
    },
    {
      "type": "infrastructure",
      "spec_version": "2.1",
      "id": "infrastructure--nexus-c2-001",
      "created": "2026-04-03T14:20:00.000Z",
      "modified": "2026-04-03T14:20:00.000Z",
      "name": "NEXUS-PHISH C2 and Phishing Server",
      "description": "DigitalOcean droplet hosting SheetRAT C2 (Werkzeug/Python on port 5001), Puppeteer phishing proxy (Express/Node.js on port 8080), and nginx reverse proxy serving 6+ phishing campaigns.",
      "infrastructure_types": [
        "command-and-control",
        "phishing"
      ]
    },
    {
      "type": "campaign",
      "spec_version": "2.1",
      "id": "campaign--nexus-phish-001",
      "created": "2026-04-03T14:20:00.000Z",
      "modified": "2026-04-03T14:20:00.000Z",
      "name": "NEXUS-PHISH Multi-Brand Campaign",
      "description": "Multi-campaign phishing operation targeting Bank of America, Chase, Amazon, Microsoft O365, Yahoo, OpenSea, Huntington, and credit unions from a single DigitalOcean droplet. All domains registered via same Cloudflare account in Feb 2026.",
