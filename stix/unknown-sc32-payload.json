    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--investigation-summary",
      "created": "2026-04-01T04:26:03.000Z",
      "modified": "2026-04-01T04:26:03.000Z",
      "content": "Investigation initiated from ThreatFox IOC hxxp://150.241.65.94/sc32 (reporter: Lenny_3BO, 2026-03-31). Payload was unrecoverable (host firewalled). Passive recon revealed the IP belongs to inteid.net (Cloudflare-proxied, UZ registrant with Cyrillic WHOIS data) hosted on Intezio Worldwide Limited BPH infrastructure (AS207567). The same hosting network services 4 confirmed Stealc C2 servers and 1 Rhadamanthys C2 server across two /24 prefixes. The /24 containing the target IP also hosts Russian VPN services, anti-Roskomnadzor proxies, and IPs spoofing Apple iCloud and Samsung CDN hostnames. Attribution confidence: MEDIUM for Russian-language operator(s).",
      "object_refs": [
        "infrastructure--intezio-bph-001",
        "infrastructure--inteid-net-001",
        "malware--sc32-unknown-001",
        "malware--stealc-001",
        "malware--rhadamanthys-001"
      ]
    }
