      "created": "2026-04-03T16:21:28Z",
      "modified": "2026-04-03T16:21:28Z",
      "name": "CrestSnake Kramer-Obfuscated Python RATs",
      "description": "Suite of 5 Python 3.12 compiled bytecode payloads using Kramer class obfuscation. Includes suspected AsyncRAT, AnyDesk RAT, HVNC, and UK-targeted variants. Deployed with bundled Python 3.12 runtime.",
      "malware_types": [
        "remote-access-trojan",
        "spyware"
      ],
      "is_family": true,
      "capabilities": [
        "communicates-with-c2",
        "persists-after-system-reboot"
      ]
    },
