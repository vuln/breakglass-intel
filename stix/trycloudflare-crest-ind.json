      "name": "Crest Snake Operator",
      "description": "Unattributed threat actor operating multi-tunnel Cloudflare infrastructure for malware delivery targeting UK and German victims. Active since at least September 2025. Uses WsgiDAV open directories, WSH/WSF dropper chains, Python-based RATs, and native DLL with Early Bird APC injection.",
      "threat_actor_types": [
        "criminal"
      ],
      "aliases": [
        "Nutten Tunnel Operator"
      ],
      "sophistication": "advanced",
      "primary_motivation": "personal-gain",
      "roles": [
        "operator",
        "infrastructure-owner"
      ]
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--572ae50e-c323-4c39-aef7-ddbb5befd47e",
      "created": "2026-04-03T16:21:28Z",
      "modified": "2026-04-03T16:21:28Z",
      "name": "CrestSnake EarlyBird DLL Loader",
      "description": "x64 DLL with exported functions get_payload, inject_early_bird, xor_decrypt. XOR-decrypts magde.dat payload and injects via Early Bird APC injection. Compiled with MinGW-Builds GCC 15.1.0.",
      "malware_types": [
        "trojan",
        "loader"
      ],
      "is_family": false,
      "capabilities": [
        "anti-detection",
        "installs-other-components"
      ],
      "implementation_languages": [
        "c"
      ]
    },
    {
