# Breakglass Intelligence - SumUp Phishing Kit Detection Rules
# Campaign: Live Control Panel Premium (SumUp)
# Date: 2026-03-31

# Detect SumUp phishing kit login page
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit Login Page Detected"; flow:established,to_server; content:"send.php"; http_uri; content:"challenge"; http_client_body; content:"locale"; http_client_body; reference:url,intel.breakglass.tech; classtype:social-engineering; sid:9000401; rev:1;)

# Detect SumUp phishing kit keepAlive beacon
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit KeepAlive Beacon"; flow:established,to_server; content:"processor.php"; http_uri; content:"keepAlive"; http_client_body; content:"page"; http_client_body; reference:url,intel.breakglass.tech; classtype:trojan-activity; sid:9000402; rev:1;)

# Detect SumUp phishing kit redirect listener
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit Redirect Listener"; flow:established,to_server; content:"processor.php"; http_uri; content:"redirectionListener"; http_client_body; reference:url,intel.breakglass.tech; classtype:trojan-activity; sid:9000403; rev:1;)

# Detect SumUp phishing kit OTP submission
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit OTP Submission"; flow:established,to_server; content:"send.php"; http_uri; pcre:"/^[0-9]=[0-9]&[0-9]=[0-9]&[0-9]=[0-9]&[0-9]=[0-9]&[0-9]=[0-9]&[0-9]=[0-9]/P"; reference:url,intel.breakglass.tech; classtype:social-engineering; sid:9000404; rev:1;)

# Detect SumUp phishing kit victim data exfiltration
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit Victim Data Query"; flow:established,to_server; content:"processor.php"; http_uri; content:"getVictimData"; http_client_body; reference:url,intel.breakglass.tech; classtype:trojan-activity; sid:9000405; rev:1;)

# Detect access to known SumUp phishing kit panel
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"BGI - SumUp Phishing Kit Admin Panel Access"; flow:established,from_server; content:"Live Control Panel Premium"; http_server_body; content:"CONTROL VICTIM"; http_server_body; reference:url,intel.breakglass.tech; classtype:social-engineering; sid:9000406; rev:1;)

